Sub SearchContact()
    name = InputBox("Enter name to search:", "Searcffh Contact")
    found = False
    For i = 0 To 4
        If LCase(contacts(i, 0)) = LCase(name) Then
            MsgBox "Found: " & contacts(i, 0) & " - " & contacts(i, 1), vbInformation
            found = True
            Exit For
        End If
    Next
    If Not found Then
        MsgBox "Contact not found!", vbExclamation
    End If
End Sub
